# Which source to use: seatgeek | ticketmaster
SOURCE=ticketmaster

# Ticketmaster Discovery API (https://developer-acct.ticketmaster.com/user/register)
TICKETMASTER_API_KEY=
TICKETMASTER_EVENT_ID=

# SeatGeek Platform API (https://developer.seatgeek.com/)
SEATGEEK_CLIENT_ID=
SEATGEEK_EVENT_ID=

# Discord webhook URL for the alerts channel
DISCORD_WEBHOOK_URL=

# Polling interval in seconds (default 60)
POLL_INTERVAL_SECONDS=60

# Optional: bind a status page HTTP server on this port (omit/0 to disable)
HTTP_PORT=

# Optional: path prefix when behind a reverse proxy (e.g. /ticket-monitor)
PUBLIC_BASE_PATH=

# Set to 1 to use synthetic mock data instead of a real source
MOCK=0
